<?xml version="1.0" encoding="UTF-8"?>
<xs:schema attributeFormDefault="unqualified" elementFormDefault="qualified" xmlns:xs="http://www.w3.org/2001/XMLSchema">
  <xs:element name="NationalParks">
    <xs:annotation>
      <xs:documentation>XML Schema for the national parks directory.</xs:documentation>
    </xs:annotation>
    <xs:complexType>
      <xs:sequence>
        <xs:element name="NationalPark" maxOccurs="unbounded" minOccurs="1">
          <xs:complexType>
            <xs:sequence>
              <xs:element type="xs:string" name="Name" minOccurs="1" maxOccurs="1"/>
              <xs:element type="xs:string" name="Phone" maxOccurs="unbounded" minOccurs="1"/>
              <xs:element name="Address" minOccurs="1" maxOccurs="1">
                <xs:complexType>
                  <xs:sequence>
                    <xs:element type="xs:string" name="Number" minOccurs="1" maxOccurs="1"/>
                    <xs:element type="xs:string" name="Street" minOccurs="1" maxOccurs="1"/>
                    <xs:element type="xs:string" name="City" minOccurs="1" maxOccurs="1"/>
                    <xs:element type="xs:string" name="State" minOccurs="1" maxOccurs="1"/>
                    <xs:element type="xs:string" name="Zip" minOccurs="1" maxOccurs="1"/>
                  </xs:sequence>
                  <xs:attribute type="xs:string" name="NearestAirport" use="required"/>
                </xs:complexType>
              </xs:element>
            </xs:sequence>
            <xs:attribute type="xs:decimal" name="Rating" use="optional"/>
          </xs:complexType>
        </xs:element>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
</xs:schema>
